#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source /usr/share/yunohost/helpers

# At this point YunoHost has already re-provisioned resources and a safety
# backup of the previous install has been created automatically.
#
# Settings automatically available as bash variables:
#   $app, $domain, $path, $install_dir, $port

#=================================================
# STOP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Stopping $app's systemd service..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# LOAD EXISTING SECRETS
# CRITICAL: Read from stored settings — NEVER regenerate on upgrade.
# Changing db_pwd would break DB access; changing app_encryption_key would
# corrupt all encrypted data in the database.
#=================================================
ynh_script_progression "Loading existing configuration secrets..."

set +x

db_pwd=$(ynh_app_setting_get --key=db_pwd)
app_encryption_key=$(ynh_app_setting_get --key=app_encryption_key)

set -x

# Settings automatically available as bash variables: db_pwd and app_encryption_key

#=================================================
# ENSURE CACHE SERVER IS RUNNING
#=================================================
# Handled by YunoHost natively as redis-server in [resources.apt].

#=================================================
# UPGRADE BINARY
#=================================================
ynh_script_progression "Upgrading Calagopus Panel binary to latest release..."

ynh_setup_source --dest_dir="$install_dir"
chmod +x "$install_dir/calagopus-panel"
chown "$app:$app" "$install_dir/calagopus-panel"

#=================================================
# ENSURE POSTGRESQL IS RUNNING
#=================================================
# PostgreSQL is handled by YunoHost natively.

#=================================================
# UPDATE .env CONFIGURATION FILE
#=================================================
ynh_script_progression "Updating configuration file..."

# ynh_config_add will:
# 1. Detect if /etc/calagopus/.env was manually modified (via checksum)
# 2. If modified, back up the manual version before overwriting
# 3. Re-generate from template with current settings (preserving secrets from settings)
set +x
ynh_config_add --template=".env" --destination="$install_dir/.env"
set -x

chown "$app:$app" "$install_dir/.env"
chmod 600 "$install_dir/.env"

# Ensure symlink at /etc/calagopus/.env exists (may be missing on upgrades from older versions)
mkdir -p /etc/calagopus
ln -sf "$install_dir/.env" /etc/calagopus/.env
chown -h "$app:$app" /etc/calagopus/.env

#=================================================
# ENSURE LOG DIRECTORY EXISTS
#=================================================
ynh_script_progression "Ensuring log directory is present..."

mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"
chmod 750 "/var/log/$app"

#=================================================
# REAPPLY SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Upgrading system configurations related to $app..."

# Re-apply systemd unit (picks up any template changes in this version)
ynh_config_add_systemd

# Re-register with YunoHost service manager
yunohost service add "$app" \
    --description="Calagopus Panel — Game Server Management Interface" \
    --log="/var/log/$app/$app.log"

# Re-apply NGINX config (picks up any template changes)
ynh_config_add_nginx

# Re-apply logrotate config
ynh_config_add_logrotate

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start"

# Brief wait to let the service initialize
sleep 3

if ! systemctl is-active --quiet "$app"; then
    ynh_die "Calagopus Panel service failed to start after upgrade. Check logs at /var/log/$app/$app.log"
fi

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed successfully."
