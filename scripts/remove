#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source /usr/share/yunohost/helpers

# After this script runs, YunoHost will automatically deprovision:
#   - The system user ($app)
#   - The install directory ($install_dir = /opt/calagopus)
#   - APT packages (only if no other app uses them)
#
# This script must manually clean up everything else that install created.

#=================================================
# LOAD SETTINGS
#=================================================

# Settings are handled automatically by YunoHost remove script.
# We do not need to drop the database manually anymore as
# YunoHost's [resources.database] handles it.

#=================================================
# STOP AND REMOVE SERVICE FROM YUNOHOST
#=================================================
ynh_script_progression "Removing system configurations related to $app..."

# Gracefully stop the service before removing anything
if ynh_hide_warnings systemctl is-active "$app"; then
    ynh_systemctl --service="$app" --action="stop"
fi

# Unregister from YunoHost service manager (removes from webadmin list)
if ynh_hide_warnings yunohost service status "$app" > /dev/null; then
    yunohost service remove "$app"
fi

# Remove and disable the systemd unit file
ynh_config_remove_systemd

#=================================================
# REMOVE NGINX CONFIGURATION
#=================================================

ynh_config_remove_nginx

#=================================================
# REMOVE LOGROTATE CONFIGURATION
#=================================================

ynh_config_remove_logrotate

#=================================================
# REMOVE CALAGOPUS BINARY
#=================================================
# YunoHost automatically removes $install_dir during [resources.install_dir] cleanup,
# which now contains the binary and .env files.
# It also automatically drops the database via [resources.database].

#=================================================
# REMOVE LOG DIRECTORY
#=================================================
ynh_script_progression "Removing log directory /var/log/$app..."

rm -rf "/var/log/$app"

#=================================================
# REMOVE /etc/calagopus SYMLINK AND DIRECTORY
#=================================================
ynh_script_progression "Removing /etc/calagopus configuration directory..."

rm -f /etc/calagopus/.env
rmdir /etc/calagopus 2>/dev/null || true

#=================================================
# NOTE ON CACHE SERVER
#=================================================
# We intentionally do NOT stop or remove Valkey/Redis here.
# Another application on this YunoHost instance may be using the same
# cache server. APT package removal (if no other app uses it) is handled
# by the YunoHost core via the [resources.apt] deprovisioning step.

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Removal of $app completed."
