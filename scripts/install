#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source /usr/share/yunohost/helpers

# At this point YunoHost has already:
#   - Created the system user: $app (= "calagopus")
#   - Created the install dir: $install_dir (= /opt/calagopus)
#   - Found a free port near 8000: $port
#   - Installed APT packages: postgresql, curl
#
# Settings automatically available as bash variables:
#   $app, $domain, $path, $install_dir, $port

#=================================================
# GENERATE AND STORE SECRETS
# Run print_OFF so these never appear in install logs
#=================================================
ynh_script_progression "Generating secrets..."

set +x

# 16-character alphanumeric encryption key (exactly as required by Calagopus)
app_encryption_key=$(cat /dev/urandom | LC_ALL=C tr -dc 'a-zA-Z0-9' | fold -w 16 | head -n 1)
ynh_app_setting_set --key=app_encryption_key --value="$app_encryption_key"

set -x

#=================================================
# INSTALL CALAGOPUS BINARY
#=================================================
ynh_script_progression "Downloading Calagopus Panel binary..."

ynh_setup_source --dest_dir="$install_dir"
chmod +x "$install_dir/calagopus-panel"
chown "$app:$app" "$install_dir/calagopus-panel"

#=================================================
# GENERATE .env FROM TEMPLATE
#=================================================
ynh_script_progression "Generating .env configuration file..."

# ynh_config_add reads conf/.env, replaces __TOKENS__ with matching bash
# variable names (case-insensitive, underscored), and stores a checksum.
#
# Token mapping (conf/.env → bash variable):
#   __DB_USER__            → $db_user
#   __DB_PWD__             → $db_pwd
#   __DB_NAME__            → $db_name
#   __PORT__               → $port
#   __APP_ENCRYPTION_KEY__ → $app_encryption_key
#   __APP__                → $app
#   __DOMAIN__             → $domain

set +x
ynh_config_add --template=".env" --destination="$install_dir/.env"
set -x

chown "$app:$app" "$install_dir/.env"
chmod 600 "$install_dir/.env"

# Create symlink at /etc/calagopus/.env → $install_dir/.env
# The upstream calagopus-panel binary expects its .env at /etc/calagopus/.env
mkdir -p /etc/calagopus
ln -sf "$install_dir/.env" /etc/calagopus/.env
chown -h "$app:$app" /etc/calagopus/.env

#=================================================
# CREATE LOG DIRECTORY
#=================================================
ynh_script_progression "Creating log directory..."

mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"
chmod 750 "/var/log/$app"

#=================================================
# SYSTEM CONFIGURATION — SYSTEMD
#=================================================
ynh_script_progression "Configuring systemd service..."

# Processes conf/systemd.service → /etc/systemd/system/$app.service
# Tokens replaced: __APP__, __INSTALL_DIR__
ynh_config_add_systemd

# Register the service in the YunoHost admin interface
yunohost service add "$app" \
    --description="Calagopus Panel — Game Server Management Interface" \
    --log="/var/log/$app/$app.log"

#=================================================
# SYSTEM CONFIGURATION — NGINX
#=================================================
ynh_script_progression "Configuring NGINX reverse proxy..."

# Processes conf/nginx.conf → /etc/nginx/conf.d/$domain.d/$app.conf
# Tokens replaced: __PATH__, __PORT__, __APP__, __DOMAIN__, __INSTALL_DIR__
ynh_config_add_nginx

#=================================================
# SYSTEM CONFIGURATION — LOGROTATE
#=================================================
ynh_script_progression "Configuring log rotation..."

# Configures logrotate for /var/log/$app/
ynh_config_add_logrotate

#=================================================
# START THE SERVICE
#=================================================
ynh_script_progression "Starting Calagopus Panel service..."

ynh_systemctl --service="$app" --action="start"

# Brief wait to let the service initialize and confirm it stays up
sleep 3

# Verify the service is actually running
if ! systemctl is-active --quiet "$app"; then
    ynh_die "Calagopus Panel service failed to start. Check logs at /var/log/$app/$app.log"
fi

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed successfully!
The Calagopus Panel OOBE (first-time setup) is available at https://$domain$path
Complete the initial setup there to create your administrator account."
