#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

# In backup/restore scripts, _common.sh is sourced from the settings copy
source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

ynh_print_info "Declaring files to be backed up..."

# IMPORTANT: ynh_backup calls are *declarations* only.
# The actual file copying into the archive happens in the YunoHost core
# after this script completes. Most ynh_backup calls are therefore instant.

#=================================================
# BACKUP THE ENVIRONMENT CONFIGURATION
# Contains all secrets — this is the most critical file to back up
#=================================================

ynh_print_info "Backing up /etc/calagopus/.env (configuration and secrets)..."

ynh_backup --src_path="/etc/calagopus/.env"

#=================================================
# BACKUP SYSTEM CONFIGURATION FILES
#=================================================

ynh_print_info "Backing up system configuration files..."

# NGINX virtual host config for this app
ynh_backup --src_path="/etc/nginx/conf.d/$domain.d/$app.conf"

# systemd unit file
ynh_backup --src_path="/etc/systemd/system/$app.service"

# logrotate config
ynh_backup --src_path="/etc/logrotate.d/$app"

#=================================================
# BACKUP POSTGRESQL DATABASE
# pg_dump runs now (takes real time) — the dump file is then included in the archive
#=================================================
ynh_print_info "Backing up PostgreSQL database '$db_name'..."

db_name=$(ynh_app_setting_get --key=db_name)
db_name="${db_name:-$app}"

# Dump to a file in the current working directory (YNH_CWD)
# The core will include this file in the archive automatically
sudo --login --user=postgres \
    pg_dump \
    --clean \
    --if-exists \
    --no-acl \
    --no-owner \
    "$db_name" \
    > "./db.sql" \
    || ynh_die "PostgreSQL dump of '$db_name' failed."

ynh_print_info "PostgreSQL dump completed: ./db.sql"

#=================================================
# NOTE: Binary NOT backed up
# The Calagopus binary at /usr/local/bin/calagopus-panel is NOT included.
# It can be re-downloaded from GitHub during restore, keeping the archive
# small and ensuring the latest binary is always used on restore.
#=================================================

#=================================================
# NOTE: Log files NOT backed up
# /var/log/$app/ is excluded — logs can be large and are not essential for restore.
# They are recreated empty on restore.
#=================================================

#=================================================
# END OF SCRIPT
#=================================================

ynh_print_info "Backup script completed for $app. (YunoHost will now copy declared files into the archive.)"
