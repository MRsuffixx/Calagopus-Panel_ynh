#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

# In backup/restore scripts, _common.sh is sourced from the settings copy
source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

# At this point YunoHost has already:
#   - Re-created the system user ($app)
#   - Re-created the install directory ($install_dir)
#   - Re-installed APT packages (postgresql, curl)
#
# Settings are loaded from the backed-up app settings, so $domain, $path,
# $port, $install_dir, and all custom settings are already available.

#=================================================
# LOAD SETTINGS
#=================================================

db_user=$(ynh_app_setting_get --key=db_user)
db_name=$(ynh_app_setting_get --key=db_name)
cache_service=$(ynh_app_setting_get --key=cache_service)

db_user="${db_user:-$app}"
db_name="${db_name:-$app}"

set +x
db_pwd=$(ynh_app_setting_get --key=db_pwd)
app_encryption_key=$(ynh_app_setting_get --key=app_encryption_key)
set -x

#=================================================
# RESTORE THE .env CONFIGURATION
#=================================================
ynh_script_progression "Restoring configuration directory..."

# Re-create /etc/calagopus if it was removed
ynh_calagopus_setup_config_dir

# Restore the .env from the archive — this restores all secrets as-is
ynh_restore "/etc/calagopus/.env"

# Re-apply correct permissions to the restored file
ynh_calagopus_fix_env_perms

#=================================================
# RE-DOWNLOAD THE CALAGOPUS BINARY
# The binary is not stored in the backup archive; always fetch from GitHub.
# This ensures we get a working binary compatible with the restored .env config.
#=================================================
ynh_script_progression "Re-downloading Calagopus Panel binary..."

ynh_download_calagopus_binary

#=================================================
# ENSURE CACHE SERVER IS RUNNING
#=================================================
ynh_script_progression "Ensuring cache server is running..."

if [ -n "$cache_service" ]; then
    # Try to start the previously-used cache server
    if ! systemctl is-active --quiet "$cache_service"; then
        systemctl start "$cache_service" 2>/dev/null || {
            ynh_print_warn "$cache_service is not available — attempting to install cache server..."
            ynh_install_calagopus_cache
        }
    fi
else
    # cache_service setting not found — install and detect
    ynh_install_calagopus_cache
fi

#=================================================
# RESTORE POSTGRESQL DATABASE
#=================================================
ynh_script_progression "Restoring PostgreSQL database..."

# Ensure PostgreSQL is running
systemctl enable postgresql --quiet
systemctl start postgresql

# Re-create the database user and database (they were dropped on remove or
# are absent on a fresh server restore target)
set +x
ynh_calagopus_setup_db "$db_user" "$db_name" "$db_pwd"
set -x

# Restore the database from the plain-text SQL dump file in the backup archive
# We use psql with stdin redirection to avoid file permission issues.
sudo --login --user=postgres \
    psql \
    --dbname="$db_name" \
    < "${YNH_CWD}/db.sql" \
    || ynh_die "PostgreSQL restore of '$db_name' from db.sql failed."

ynh_script_progression "PostgreSQL database '$db_name' restored successfully."

#=================================================
# CREATE LOG DIRECTORY
#=================================================
ynh_script_progression "Creating log directory..."

ynh_calagopus_setup_log_dir

#=================================================
# RESTORE SYSTEM CONFIGURATION — NGINX
#=================================================
ynh_script_progression "Restoring NGINX configuration..."

ynh_restore "/etc/nginx/conf.d/$domain.d/$app.conf"

#=================================================
# RESTORE SYSTEM CONFIGURATION — SYSTEMD
#=================================================
ynh_script_progression "Restoring systemd service..."

ynh_restore "/etc/systemd/system/$app.service"

# Re-enable the unit so it starts on boot
systemctl enable "$app.service" --quiet
systemctl daemon-reload

# Re-register the service with YunoHost
yunohost service add "$app" \
    --description="Calagopus Panel — Game Server Management Interface" \
    --log="/var/log/$app/$app.log"

#=================================================
# RESTORE SYSTEM CONFIGURATION — LOGROTATE
#=================================================
ynh_script_progression "Restoring logrotate configuration..."

ynh_restore "/etc/logrotate.d/$app"

#=================================================
# START SERVICE AND RELOAD NGINX
#=================================================
ynh_script_progression "Starting $app service and reloading NGINX..."

ynh_systemctl --service="$app" --action="start"

# Brief wait for the service to stabilize
sleep 3

if ! systemctl is-active --quiet "$app"; then
    ynh_die "Calagopus Panel service failed to start after restore. Check logs at /var/log/$app/$app.log"
fi

ynh_systemctl --service=nginx --action=reload

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Restoration of $app completed successfully.
Your Calagopus Panel should be accessible at https://$domain$path"
