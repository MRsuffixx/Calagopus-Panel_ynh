# =============================================================================
# Calagopus Panel — Environment Configuration
# Generated by YunoHost during installation.
# DO NOT EDIT MANUALLY — changes may be overwritten on upgrade.
# Managed at: __INSTALL_DIR__/.env
# Permissions: 600 (readable only by the calagopus service user)
# =============================================================================

# -----------------------------------------------------------------------------
# Redis / Valkey Cache
# REDIS_MODE: "redis" for a single instance (default), "sentinel" for HA cluster
# REDIS_URL: connection string for the cache server
# Both Valkey and Redis listen on port 6379 by default on localhost
# -----------------------------------------------------------------------------
REDIS_MODE=redis
REDIS_URL="redis://127.0.0.1:6379"

# -----------------------------------------------------------------------------
# PostgreSQL Database
# Format: postgresql://user:password@host:port/database
# __DB_USER__, __DB_PWD__, __DB_NAME__ are replaced by the install script
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://__DB_USER__:__DB_PWD__@localhost:5432/__DB_NAME__"

# Auto-run database migrations on startup.
# In single-node YunoHost deployments this should always be true.
DATABASE_MIGRATE=true

# -----------------------------------------------------------------------------
# HTTP Server Binding
# BIND=127.0.0.1 ensures the panel is NOT directly reachable from the internet.
# All traffic must flow through the NGINX reverse proxy.
# PORT is the local-only port that NGINX forwards to.
# -----------------------------------------------------------------------------
BIND=127.0.0.1
PORT=__PORT__

# -----------------------------------------------------------------------------
# Application Settings
# APP_PRIMARY: true on single-node; designates this instance to run background tasks
# APP_DEBUG: always false in production; set to true only for troubleshooting
# APP_ENABLE_WINGS_PROXY: set false — direct Wings connections are preferred
# APP_USE_DECRYPTION_CACHE: false — caching decrypted values in Redis is a
#   security tradeoff; disabled for a safer default
# APP_USE_INTERNAL_CACHE: true — in-memory short-lived cache; safe on single node
# -----------------------------------------------------------------------------
APP_PRIMARY=true
APP_DEBUG=false
APP_ENABLE_WINGS_PROXY=false
APP_USE_DECRYPTION_CACHE=false
APP_USE_INTERNAL_CACHE=true

# -----------------------------------------------------------------------------
# Encryption Key
# REQUIRED — used to encrypt sensitive data (tokens, credentials) in the database.
# Must be exactly 16 alphanumeric characters.
# Generated once during installation and stored in YunoHost settings.
# NEVER change this after installation — it will break existing encrypted data.
# __APP_ENCRYPTION_KEY__ is replaced by the install script.
# -----------------------------------------------------------------------------
APP_ENCRYPTION_KEY="__APP_ENCRYPTION_KEY__"

# -----------------------------------------------------------------------------
# Trusted Proxy IPs
# Since the panel sits behind NGINX on the same host, only 127.0.0.1 is trusted.
# This allows the panel to correctly read the real client IP from X-Forwarded-For.
# Multiple IPs/CIDRs can be comma-separated: e.g. 127.0.0.1,10.0.0.0/8
# -----------------------------------------------------------------------------
APP_TRUSTED_PROXIES=127.0.0.1

# -----------------------------------------------------------------------------
# Logging
# APP_LOG_DIRECTORY: directory where the panel writes its own log files.
# Set to the YunoHost standard log path for this app.
# Logrotate is configured separately to rotate these logs automatically.
# -----------------------------------------------------------------------------
APP_LOG_DIRECTORY=/var/log/__APP__

# -----------------------------------------------------------------------------
# Server Identification
# SERVER_NAME: display name for this panel instance.
# Useful for identification in multi-panel setups and Sentry error tracking.
# Set to the installation domain by default.
# -----------------------------------------------------------------------------
SERVER_NAME=__DOMAIN__

# -----------------------------------------------------------------------------
# Sentry Error Tracking (optional)
# Uncomment and fill in your Sentry DSN to enable error reporting.
# Leave commented or empty to disable.
# -----------------------------------------------------------------------------
# SENTRY_URL=

# -----------------------------------------------------------------------------
# Advanced: Read Replica (optional)
# Set DATABASE_URL_PRIMARY if you want to separate read and write traffic.
# Leave unset for a standard single-PostgreSQL setup.
# -----------------------------------------------------------------------------
# DATABASE_URL_PRIMARY=
